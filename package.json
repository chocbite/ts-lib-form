{
  "name": "@chocbite/ts-lib-form",
  "version": "1.4.4",
  "description": "Form fields UI library for TypeScript",
  "author": "chocolateandmilkwin",
  "license": "MIT",
  "type": "module",
  "private": false,
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "style": "./dist/style.css",
  "repository": {
    "url": "git+https://forgejo.nsns.dk/chocbite/ts-lib-form.git",
    "type": "git"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "style": "./dist/style.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --port 9989 --host",
    "build": "tsdown src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "check-deps": "npx depcheck",
    "check-trials": "tsc --noEmit",
    "prepublishOnly": "npm run check-deps && npm run check-trials && npm run build",
    "upgrades": "npx npm-check-updates --target semver",
    "upgrade": "npx npm-check-updates --target semver -u && npm install"
  },
  "devDependencies": {
    "@chocbite/ts-supplement-eslint": "^1.0.4",
    "@chocbite/ts-lib-common": "^1.4.0",
    "@chocbite/ts-lib-icons": "^1.3.0",
    "@tsdown/css": "^0.21.10",
    "@vitest/browser-playwright": "^4.1.9",
    "eslint": "^10.6.0",
    "sass-embedded": "^1.100.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@chocbite/ts-lib-result": "^1.4.1",
    "@chocbite/ts-lib-svg": "^1.2.0",
    "@chocbite/ts-lib-math": "^1.1.2",
    "@chocbite/ts-lib-colors": "^1.1.0",
    "@chocbite/ts-lib-string": "^1.1.0",
    "@chocbite/ts-lib-list": "^1.2.4",
    "@chocbite/ts-lib-base": "^1.8.1",
    "@chocbite/ts-lib-theme": "^1.4.0",
    "@chocbite/ts-lib-state": "^2.2.1"
  }
}
